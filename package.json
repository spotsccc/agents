{
  "private": true,
  "scripts": {
    "supabase:gen-types": "pnpm --filter supabase gen:types",
    "supabase:functions-serve": "pnpm --filter supabase functions:serve",
    "supabase:functions-deploy": "pnpm --filter supabase functions:deploy",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:console": "supabase console",
    "supabase:db:push": "pnpm --filter supabase db:push",
    "supabase:link:ci": "pnpm --filter supabase link:ci",
    "supabase:db:push:ci": "pnpm --filter supabase db:push:ci",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "test:unit": "turbo run test:unit",
    "test:e2e": "pnpm --filter web test:e2e",
    "playwright:install": "pnpm --filter web exec playwright install --with-deps",
    "test:all": "pnpm test:unit && pnpm test:e2e"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "with-vite-react",
  "dependencies": {
    "supabase": "^2.58.5"
  }
}
