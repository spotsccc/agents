{
  "name": "bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "BOT_MODE=polling tsx watch src/dev.ts",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "grammy": "^1.35.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@agents/eslint-config": "workspace:*",
    "@agents/prettier-config": "workspace:*",
    "@agents/typescript-config": "workspace:*",
    "@types/node": "^22.15.32",
    "eslint": "^9.29.0",
    "prettier": "^3.2.5",
    "tsx": "^4.19.4",
    "typescript": "~5.9.2",
    "vitest": "^4.0.17"
  }
}
